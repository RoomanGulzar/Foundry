@model ChangeRequestAnalyzer.Web.Models.ChangeRequestDetailsViewModel

@{
    ViewData["Title"] = "Change Request Details";
}

<h1>Change Request Details</h1>
<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary">Back to list</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h4>@Model.Title</h4>
        <p class="text-muted">Status: @Model.Status</p>
        <p>@Model.Description</p>
        <p class="mb-1"><strong>Created:</strong> @Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p>
        <p class="mb-0"><strong>Analyzed:</strong> @(Model.AnalyzedAt.HasValue ? Model.AnalyzedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "Pending")</p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header">User Stories</div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    @foreach (var story in Model.UserStories)
                    {
                        <li class="list-group-item">
                            <strong>@story.StoryIdentifier</strong>: @story.RequirementText
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header">Analysis Results</div>
            <div class="card-body">
                <div class="mb-3">
                    <h6>Target Files</h6>
                    <pre class="bg-light p-3">@Model.TargetFiles</pre>
                </div>
                <div class="mb-3">
                    <h6>Conflicting Files</h6>
                    <pre class="bg-light p-3">@Model.ConflictingFiles</pre>
                </div>
                <div>
                    <h6>Generated Prompt</h6>
                    <pre class="bg-light p-3">@Model.GeneratedPrompt</pre>
                </div>
            </div>
        </div>
    </div>
</div>
