@model IReadOnlyCollection<ChangeRequestAnalyzer.Web.Models.ChangeRequestDetailsViewModel>

@{
    ViewData["Title"] = "Change Requests";
}

<h1 class="mb-4">Change Request Analyzer</h1>
<p>
    <a asp-action="Create" class="btn btn-primary">Upload New Change Request</a>
</p>

<table class="table table-striped table-bordered">
    <thead class="table-light">
        <tr>
            <th>Title</th>
            <th>Status</th>
            <th>Created</th>
            <th>User Stories</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Status</td>
                <td>@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                <td>@item.UserStories.Count</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>
